---
import BaseLayout from '../layouts/BaseLayout.astro';

// Manually curated post list. Add new posts here as they are published on Substack.
// Substack URL pattern: https://uncledata.substack.com/p/<slug>
// TODO: Tomas — fill in the full post archive, sorted newest first.

interface Post {
  title: string;
  url: string;
  date: string;
  description: string;
}

const posts: Post[] = [
  {
    title: 'What I actually do as a fractional data leader',
    url: 'https://uncledata.substack.com/p/what-i-actually-do-as-a-fractional',
    date: 'March 2025',
    description: 'The job title is new. The work is not.',
  },
  {
    title: 'Tech debt is a management problem',
    url: 'https://uncledata.substack.com/p/tech-debt-is-a-management-problem',
    date: 'February 2025',
    description: 'Why rewrite campaigns fail and what to do instead.',
  },
  {
    title: 'Airflow war stories',
    url: 'https://uncledata.substack.com/p/airflow-war-stories',
    date: 'January 2025',
    description: 'Things that go wrong when you run Airflow at scale, and how to survive them.',
  },
];
---

<BaseLayout
  title="Writing | Uncle Data"
  description="Posts on data engineering, leadership, and the things they don't put in the docs."
>

  <section class="pt-16 pb-6 max-w-2xl">
    <h1 class="font-heading text-4xl text-bg-dark mb-6">Writing</h1>
    <p class="font-body text-bg-dark/70 leading-relaxed">
      Posts on data engineering, leadership, and the things they don't put in the docs. Discussion lives on Substack.
    </p>
  </section>

  <section class="max-w-2xl pb-16">
    <div class="divide-y divide-accent-peach/40">
      {posts.map((post) => (
        <div class="py-6">
          <p class="font-body text-xs text-bg-dark/40 mb-1">{post.date}</p>
          <a
            href={post.url}
            class="font-heading text-lg text-bg-dark hover:text-accent-coral transition-colors block mb-1"
            target="_blank"
            rel="noopener noreferrer"
          >
            {post.title}
          </a>
          {post.description && (
            <p class="font-body text-sm text-bg-dark/60 leading-relaxed">{post.description}</p>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="border-t border-accent-peach/40 py-10 max-w-2xl">
    <p class="font-body text-bg-dark/70">
      Want these in your inbox?{' '}
      <a
        href="https://uncledata.substack.com/?utm_source=site&utm_medium=cta&utm_campaign=writing"
        class="text-accent-coral hover:text-accent-coral-deep transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        Subscribe on Substack.
      </a>
    </p>
  </section>

</BaseLayout>
