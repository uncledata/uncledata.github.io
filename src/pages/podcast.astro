---
import BaseLayout from '../layouts/BaseLayout.astro';

const spotifyShowId = '414izixQNC4wNnQfatrvgT';
const applePodcastsUrl = ''; // e.g. 'https://podcasts.apple.com/...'
---

<BaseLayout
  title="Podcast | Uncle Data"
  description="The Uncle Data podcast: conversations with people who build and run data teams."
>

  <section class="pt-16 pb-6 max-w-2xl">
    <h1 class="font-heading text-4xl text-bg-dark mb-3">The Uncle Data podcast.</h1>
    <p class="font-body text-bg-dark/70 leading-relaxed">
      Conversations with people who actually do the work of building and running data teams. New episodes irregularly.
    </p>
  </section>

  <section class="max-w-2xl pb-8">
    <iframe
      style="border-radius:12px"
      src={`https://open.spotify.com/embed/show/${spotifyShowId}`}
      width="100%"
      height="352"
      frameborder="0"
      allowfullscreen
      allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      loading="lazy"
      title="Uncle Data podcast on Spotify"
    ></iframe>
    <p class="font-body text-sm text-bg-dark/50 mt-3">
      <a
        href={`https://open.spotify.com/show/${spotifyShowId}`}
        class="text-accent-coral hover:text-accent-coral-deep transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        See all episodes on Spotify &rarr;
      </a>
      {applePodcastsUrl && (
        <>
          {' '}·{' '}
          <a
            href={applePodcastsUrl}
            class="text-accent-coral hover:text-accent-coral-deep transition-colors"
            target="_blank"
            rel="noopener noreferrer"
          >
            Apple Podcasts
          </a>
        </>
      )}
    </p>
  </section>

  <p class="font-body text-sm text-bg-dark/50 max-w-2xl pb-16">
    Find more writing on{' '}
    <a
      href="https://uncledata.substack.com/?utm_source=site&utm_medium=cta&utm_campaign=podcast"
      class="text-accent-coral hover:text-accent-coral-deep transition-colors"
      target="_blank"
      rel="noopener noreferrer"
    >
      Substack
    </a>.
  </p>

</BaseLayout>
